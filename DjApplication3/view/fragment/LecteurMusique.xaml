<UserControl x:Class="DjApplication3.view.page.LecteurMusique"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:DjApplication3.view.page" xmlns:local1="clr-namespace:DjApplication3.view.composentPerso"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="0,5,0,5" Background="#FF323232">
        <!-- Définition des colonnes -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Définition des lignes -->
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Label x:Name="tv_titleAuthor" Content="tv_titleAuthor" Grid.ColumnSpan="7" VerticalAlignment="Center" Foreground="#FFFDFDFD"/>
        <Label x:Name="tv_bpm" Grid.Column="7" Content="tv_bpm" Grid.ColumnSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
        <Label x:Name="tv_nbrPiste" Grid.Column="9" Content="tv_nbrPiste" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.ColumnSpan="3" Foreground="White" FontSize="20" FontWeight="Bold"/>
        <ToggleButton x:Name="btn_AutoNext" 
              Grid.Column="12" 
              Grid.ColumnSpan="2"
              Foreground="White"
              FontWeight="Bold"
              Margin="2"
              Click="btn_AutoNext_Click">
            <ToggleButton.Style>
                <Style TargetType="ToggleButton">
                    <Setter Property="Content" Value="AUTO OFF" />
                    <Setter Property="Background" Value="#FF5C5C" />

                    <Style.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Content" Value="AUTO ON" />
                            <Setter Property="Background" Value="#4CAF50" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ToggleButton.Style>
        </ToggleButton>
        <Button x:Name="bt_random" 
        Grid.Column="14"
        Click="bt_random_Click" MouseEnter="bt_random_MouseEnter"
        Background="#FF444444"
        Margin="2">
            <Button.ToolTip>
                <ToolTip x:Name="tt_random" Content="Chargement de la liste..."/>
            </Button.ToolTip>
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Rectangle x:Name="rect" Fill="{TemplateBinding Background}" RadiusX="2" RadiusY="2"/>
                        <Image Source="/DjApplication3;component/Resources/shuffle.png" 
                       Stretch="Uniform" 
                       Margin="8"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="rect" Property="Fill" Value="#FF666666"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Label x:Name="tv_durationCurrent" Content="tv_durationCurrent" HorizontalAlignment="Center" Grid.Row="4" VerticalAlignment="Center" Grid.ColumnSpan="3" Foreground="White"/>
        <Label x:Name="tv_durationTotal" Content="tv_durationTotal" HorizontalAlignment="Center" Grid.Row="4" VerticalAlignment="Center" Grid.Column="6" Grid.ColumnSpan="3" Foreground="White"/>
        <Label x:Name="tv_durationRest" Content="tv_durationRest" HorizontalAlignment="Center" Grid.Row="4" VerticalAlignment="Center" Grid.Column="12" Grid.ColumnSpan="3" Foreground="White" FontWeight="Bold"/>
        <Button x:Name="bt_playPause" Content="" Grid.Row="5" Grid.ColumnSpan="2" Click="bt_playPause_Click" Background="#FF0000">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Rectangle Fill="{TemplateBinding Background}"/>
                        <Image x:Name="img_PlayPause" Source="/DjApplication3;component/Resources/play.png" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button x:Name="bt_stop" Content="" Grid.Row="5" Grid.ColumnSpan="2" Grid.Column="2" Click="bt_stop_Click" Background="Red">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Rectangle Fill="{TemplateBinding Background}"/>
                        <Image x:Name="img_stop" Source="/DjApplication3;component/Resources/stop.png" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>
        <Button x:Name="bt_headphone" Grid.Column="13" Content="" Grid.ColumnSpan="2" Grid.Row="5" Click="bt_headphone_Click" Background="Red">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Rectangle Fill="{TemplateBinding Background}"/>
                        <Image x:Name="img_headphone" Source="/DjApplication3;component/Resources/headphone.png" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="5,5,5,5"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <local1:TrackBarPerso x:Name="tb_volume" Grid.Row="5" Grid.Column="4" Grid.ColumnSpan="9" />
        <local1:WaveView x:Name="waveForme" Grid.Row="1" Grid.RowSpan="3" Grid.ColumnSpan="15" MouseDown="waveForme_MouseDown"/>
    </Grid>
</UserControl>

